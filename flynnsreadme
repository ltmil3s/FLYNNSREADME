// ── Heatmap rendering ─────────────────────────────────────────────────────
function buildHeatmapHTML(heatMap, d, fw) {
  const maxCount = Math.max(1, ...Object.values(heatMap).map(h => h.count));
  const showSubs = fw === 'enterprise' && subTechMode === 'full';
  const parentSubsMap = d.parent_subs_map || {};
  const subTechsById  = {};
  if (d.sub_techniques) d.sub_techniques.forEach(t => subTechsById[t.id] = t);

  const tacticOrder = d.tactics.map(t => t.name);
  const byTactic = {};
  tacticOrder.forEach(t => byTactic[t] = []);
  d.techniques.forEach(tech => {
    tech.tactics.split(',').map(s => s.trim()).forEach(tact => {
      if (byTactic[tact]) byTactic[tact].push(tech);
    });
  });

  let html = '';
  tacticOrder.forEach(tacticName => {
    const techs = byTactic[tacticName];
    if (!techs.length) return;
    const tacticData = d.tactics.find(t => t.name === tacticName);

    // Tactic heat = sum of parent + sub counts in this tactic
    let tacticHeat = 0;
    techs.forEach(t => {
      tacticHeat += heatMap[t.id]?.count || 0;
      if (showSubs) {
        (parentSubsMap[t.id] || []).forEach(sid => {
          tacticHeat += heatMap[sid]?.count || 0;
        });
      }
    });

    html += `<div class="tactic-col">
      <div class="tactic-header">
        ${tacticName}
        <span class="tactic-id-small">${tacticData?.id || ''}</span>
        ${tacticHeat > 0 ? `<span class="tactic-count">◆ ${tacticHeat}</span>` : ''}
      </div>`;

    techs.forEach(tech => {
      const heat = heatMap[tech.id] || { count: 0, groups: [] };
      const subs = showSubs ? (parentSubsMap[tech.id] || []) : [];
      const hasSubs = subs.length > 0;
      const hClass = getHeatClass(heat.count, maxCount);
      const url = techUrl(tech.id);
      html += `<div class="ttp-cell ${hClass}${hasSubs ? ' has-subs' : ''}"
        data-tid="${tech.id}"
        onmouseenter="showTooltipFor(event,'${tech.id}','${fw}')"
        onmouseleave="hideTooltip()"
        onclick="window.open('${url}','_blank')">
        <div class="ttp-id">${tech.id}</div>
        <div class="ttp-name">${tech.name}</div>
        ${heat.count > 0 ? `<div class="ttp-heat">◆ ${heat.count}</div>` : ''}
        <a class="ttp-link" href="${url}" target="_blank" onclick="event.stopPropagation()">↗ MITRE</a>
      </div>`;

      // Sub-technique cells
      subs.forEach(sid => {
        const sub = subTechsById[sid];
        if (!sub) return;
        const subHeat = heatMap[sid] || { count: 0, groups: [] };
        const subClass = getHeatClass(subHeat.count, maxCount);
        const subUrl = techUrl(sid);
        // Short name: strip "ParentName: " prefix
        const shortName = sub.name.includes(': ') ? sub.name.split(': ').slice(1).join(': ') : sub.name;
        html += `<div class="ttp-cell sub-tech ${subClass}"
          data-tid="${sid}"
          onmouseenter="showTooltipFor(event,'${sid}','${fw}')"
          onmouseleave="hideTooltip()"
          onclick="window.open('${subUrl}','_blank')">
          <div class="ttp-id">${sid}</div>
          <div class="ttp-name">${shortName}</div>
          ${subHeat.count > 0 ? `<div class="ttp-heat">◆ ${subHeat.count}</div>` : ''}
          <a class="ttp-link" href="${subUrl}" target="_blank" onclick="event.stopPropagation()">↗ MITRE</a>
        </div>`;
      });
    });
    html += '</div>';
  });

  return html || `<div class="empty-state"><div class="empty-icon">⬜</div>Select threat actors to populate heatmap</div>`;
}

