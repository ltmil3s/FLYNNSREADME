// Merge ENT group_country and group_descs into top-level for API parity
const ENT_DATA = (function() {
  const d = ENT_DATA_RAW;
  // attach country/desc back onto groups array for uniform access
  d.groups.forEach(g => {
    g._country = d.group_country[g.id] || {country:'Unknown', flag:'🌐'};
    g._desc    = d.group_descs[g.id] || '';
  });
  return d;
})();

const MITRE_BASE = 'https://attack.mitre.org';
const techUrl  = id => `${MITRE_BASE}/techniques/${id}/`;
const groupUrl = id => `${MITRE_BASE}/groups/${id}/`;
const swUrl    = id => `${MITRE_BASE}/software/${id}/`;
const mitUrl   = id => `${MITRE_BASE}/mitigations/${id}/`;
const detUrl   = id => `${MITRE_BASE}/detectionstrategies/${id}/`;

// ── Framework switcher state ───────────────────────────────────────────────
let currentFramework = 'ics'; // 'ics' | 'enterprise'

function activeData()        { return currentFramework === 'ics' ? DATA : ENT_DATA; }
function activeGroupCountry(id) {
  if (currentFramework === 'ics') return ICS_GROUP_COUNTRY[id] || {country:'Unknown', flag:'🌐'};
  const d = ENT_DATA.group_country || {};
