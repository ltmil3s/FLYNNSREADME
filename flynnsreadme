// ── State ──────────────────────────────────────────────────────────────────
const selectedGroups    = new Set();  // single-mode selections
const selectedGroupsICS = new Set();  // dual-mode ICS selections
const selectedGroupsEnt = new Set();  // dual-mode Enterprise selections
let activeCountry    = null;
let activeCountryICS = null;
let activeCountryEnt = null;
let currentTab       = 'heatmap';
let subTechMode      = 'parent';   // 'parent' | 'full'
let dualMode         = false;

// Lookup maps (rebuilt on framework switch)
let techById = {};
let swById = {};
let COUNTRIES = [];

function rebuildLookups() {
  const d = activeData();
  techById = {};
  d.techniques.forEach(t => techById[t.id] = t);
  // Also index sub-techniques for Enterprise
  if (d.sub_techniques) {
    d.sub_techniques.forEach(t => techById[t.id] = t);
  }
  swById = {};
  d.software.forEach(s => swById[s.id] = s);

  // Build unique country list from active groups
  const countrySet = new Set();
  d.groups.forEach(g => {
    const info = activeGroupCountry(g.id);
    countrySet.add(info.country);
  });
  COUNTRIES = [...countrySet].sort();
}

// Initial build
rebuildLookups();

function getGroupTechs(group, fw) {
  // fw defaults to currentFramework when not specified (dual mode passes it explicitly)
  const framework = fw || currentFramework;
  const swMap = (framework === 'ics' ? DATA : ENT_DATA).sw_tech_map || {};

  // For Enterprise in full sub-tech mode use techniques_all; otherwise techniques (parents only)
  let directTechs;
  if (framework === 'enterprise' && subTechMode === 'full' && group.techniques_all) {
    directTechs = group.techniques_all;
  } else {
    directTechs = group.techniques;
  }

  const techs = new Set(directTechs);
  group.software.forEach(swId => {
    (swMap[swId] || []).forEach(t => {
      // In parent-only mode, skip sub-technique IDs (contain a dot)
      if (framework === 'enterprise' && subTechMode === 'parent' && t.includes('.')) return;
      techs.add(t);
    });
  });
  return techs;
}

function computeHeatMap() {
  // Single mode
  const hm = {};
  activeData().groups.forEach(g => {
    if (!selectedGroups.has(g.id)) return;
    getGroupTechs(g).forEach(tid => {
      if (!hm[tid]) hm[tid] = { count: 0, groups: [] };
      hm[tid].count++;
      hm[tid].groups.push(g.name);
    });
  });
  return hm;
}

function getHeatClass(count, max) {
  if (count === 0) return 'heat-0';
  if (max <= 1) return 'heat-2';
  const r = count / max;
  if (r <= 0.15) return 'heat-1';
  if (r <= 0.30) return 'heat-2';
  if (r <= 0.50) return 'heat-3';
  if (r <= 0.65) return 'heat-4';
  if (r <= 0.80) return 'heat-5';
  return 'heat-6';
}

