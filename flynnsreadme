// ── Top Detections ─────────────────────────────────────────────────────────
function renderTopDetections(hm) {
  const detCount = {};
  Object.keys(hm).forEach(tid => {
    const tech = techById[tid];
    if (!tech) return;
    tech.detections.forEach(det => {
      if (!detCount[det.id]) detCount[det.id] = { name: det.name, techIds: [], aptCount: 0 };
      detCount[det.id].techIds.push(tid);
      detCount[det.id].aptCount += hm[tid].count;
    });
  });
  const sorted = Object.entries(detCount).sort((a,b)=>b[1].aptCount-a[1].aptCount).slice(0,30);
  const max = sorted[0]?.[1].aptCount || 1;
  if (!sorted.length) { document.getElementById('topDetectionsContent').innerHTML = emptyState('🔍'); return; }

  let html = `<table class="top-list"><thead><tr>
    <th>#</th><th>Detection Strategy</th><th>Covers Techniques</th><th>Priority Score</th>
  </tr></thead><tbody>`;
  sorted.forEach(([detId, info], i) => {
    const pct = Math.round((info.aptCount/max)*100);
    const url = detUrl(detId);
    html += `<tr class="${i<3?'rank-'+(i+1):''}">
      <td class="rank-num">${i+1}</td>
      <td>
        <div class="item-id">${detId}</div>
        <div class="item-name">${info.name.replace('Detection of ','')}</div>
        <a class="mitre-link" href="${url}" target="_blank" rel="noopener noreferrer">↗ MITRE ATT&CK</a>
      </td>
      <td><div class="item-sub">${info.techIds.join(', ')}</div></td>
      <td class="bar-cell">
        <div class="bar-outer">
          <div class="bar-inner" style="width:${pct}%"></div>
          <span class="bar-count">${info.aptCount}</span>
        </div>
      </td>
    </tr>`;
  });
  html += '</tbody></table>';
  document.getElementById('topDetectionsContent').innerHTML = html;
}

// ── Top Mitigations ────────────────────────────────────────────────────────
function renderTopMitigations(hm) {
  const mitCount = {};
  Object.keys(hm).forEach(tid => {
    const tech = techById[tid];
    if (!tech) return;
    tech.mitigations.forEach(mit => {
      if (!mitCount[mit.id]) mitCount[mit.id] = { name: mit.name, techIds: [], aptCount: 0 };
      mitCount[mit.id].techIds.push(tid);
      mitCount[mit.id].aptCount += hm[tid].count;
    });
  });
  const sorted = Object.entries(mitCount).sort((a,b)=>b[1].aptCount-a[1].aptCount).slice(0,30);
  const max = sorted[0]?.[1].aptCount || 1;
  if (!sorted.length) { document.getElementById('topMitigationsContent').innerHTML = emptyState('🛡'); return; }

  let html = `<table class="top-list"><thead><tr>
    <th>#</th><th>Mitigation</th><th>Addresses Techniques</th><th>Priority Score</th>
  </tr></thead><tbody>`;
  sorted.forEach(([mitId, info], i) => {
    const pct = Math.round((info.aptCount/max)*100);
    html += `<tr class="${i<3?'rank-'+(i+1):''}">
      <td class="rank-num">${i+1}</td>
      <td>
        <div class="item-id">${mitId}</div>
        <div class="item-name">${info.name}</div>
        <a class="mitre-link" href="${mitUrl(mitId)}" target="_blank">↗ MITRE ATT&CK</a>
      </td>
      <td><div class="item-sub">${info.techIds.slice(0,8).join(', ')}${info.techIds.length>8?'…':''}</div></td>
      <td class="bar-cell">
        <div class="bar-outer">
          <div class="bar-inner orange" style="width:${pct}%"></div>
          <span class="bar-count orange">${info.aptCount}</span>
        </div>
      </td>
    </tr>`;
  });
  html += '</tbody></table>';
  document.getElementById('topMitigationsContent').innerHTML = html;
}

function emptyState(icon) {
  return `<div class="empty-state"><div class="empty-icon">${icon}</div>Select threat actors to see data</div>`;
}

// ── Tooltip ────────────────────────────────────────────────────────────────
let tooltipHideTimer = null;
function cancelHideTooltip() {
  if (tooltipHideTimer) { clearTimeout(tooltipHideTimer); tooltipHideTimer = null; }
}

function showTooltipFor(event, tid, fw) {
  // Resolve techById for the right framework
  const lookup = dualMode
    ? (fw === 'ics' ? techByIdICS : techByIdEnt)
    : techById;
  const tech = lookup[tid];
  if (!tech) return;

  // Compute relevant heatmap
  let heat;
  if (dualMode) {
    const selSet = fw === 'ics' ? selectedGroupsICS : selectedGroupsEnt;
    const groups = fw === 'ics' ? DATA.groups : ENT_DATA.groups;
    const hm = computeHeatMapFor(groups, fw, selSet);
    heat = hm[tid] || { count: 0, groups: [] };
  } else {
    const hm = computeHeatMap();
    heat = hm[tid] || { count: 0, groups: [] };
  }

  cancelHideTooltip();
  document.getElementById('tt-title').textContent = tech.name;
  document.getElementById('tt-id').textContent = tid + (tech.parent ? ` (sub of ${tech.parent})` : '');
  document.getElementById('tt-apts').textContent = heat.count > 0
    ? `◆ ${heat.count} APT(s): ${heat.groups.join(', ')}`
    : 'Not observed in selected APTs';
  document.getElementById('tt-tactic').textContent = tech.tactics;

  document.getElementById('tt-mits').innerHTML = (tech.mitigations||[]).slice(0,4).map(m =>
    `<div class="tooltip-item">${m.name}</div>`).join('') +
    ((tech.mitigations||[]).length > 4 ? `<div style="font-size:8px;color:var(--tron-dim2);padding-left:8px">+${tech.mitigations.length-4} more</div>` : '');

  document.getElementById('tt-dets').innerHTML = (tech.detections||[]).slice(0,3).map(d =>
    `<div class="tooltip-item">
      <a href="${detUrl(d.id)}" target="_blank" rel="noopener noreferrer"
         style="color:inherit;text-decoration:none;"
         onclick="event.stopPropagation()"
         onmouseover="this.style.color='var(--tron-blue)';this.style.textDecoration='underline'"
         onmouseout="this.style.color='inherit';this.style.textDecoration='none'">
        ${d.name.replace('Detection of ','')} ↗
      </a>
    </div>`).join('');

  const link = document.getElementById('tt-mitre-link');
  link.href = techUrl(tid);

  const tt = document.getElementById('tooltip');
  let x = event.clientX + 16, y = event.clientY + 10;
  tt.style.left = x + 'px';
  tt.style.top  = y + 'px';
  tt.classList.add('visible');

  setTimeout(() => {
    const r = tt.getBoundingClientRect();
    if (r.right  > window.innerWidth  - 10) tt.style.left = (x - r.width  - 22) + 'px';
    if (r.bottom > window.innerHeight - 10) tt.style.top  = (y - r.height - 22) + 'px';
  }, 0);
}

// Backward-compat shim for any remaining showTooltip(event, tid) calls
function showTooltip(event, tid) {
  showTooltipFor(event, tid, currentFramework);
}

function hideTooltip() {
  tooltipHideTimer = setTimeout(() => {
    document.getElementById('tooltip').classList.remove('visible');
  }, 250);
}

// ── CSV Export ─────────────────────────────────────────────────────────────
function openExportModal() { document.getElementById('exportModal').classList.add('visible'); }
function closeExportModal() { document.getElementById('exportModal').classList.remove('visible'); }

function csvRow(cells) {
  return cells.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',');
}

function downloadCSV(filename, rows) {
  const blob = new Blob([rows.join('\n')], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  URL.revokeObjectURL(url);
  closeExportModal();
}

function exportCSV(type) {
  const hm = computeHeatMap();
  const ts = new Date().toISOString().slice(0,10);
  const fw = currentFramework === 'ics' ? 'ics' : 'enterprise';
  const d  = activeData();

  if (type === 'ttps') {
    const rows = [csvRow(['Technique ID','Technique Name','Tactics','APT Count','APTs Using','Heat Level','MITRE URL'])];
    const maxHeat = Math.max(1,...Object.values(hm).map(h=>h.count));
    d.techniques.forEach(t => {
      const heat = hm[t.id] || {count:0, groups:[]};
      const hClass = getHeatClass(heat.count, maxHeat);
      rows.push(csvRow([t.id, t.name, t.tactics, heat.count, heat.groups.join('; '), hClass.replace('heat-',''), techUrl(t.id)]));
    });
    downloadCSV(`${fw}-attack-heatmap-ttps-${ts}.csv`, rows);
  }

  else if (type === 'groups') {
    const rows = [csvRow(['Group ID','Group Name','Country','Flag','Technique Count','Software Count','Selected','MITRE URL'])];
    d.groups.forEach(g => {
      const info = activeGroupCountry(g.id);
      const techCount = getGroupTechs(g).size;
      rows.push(csvRow([g.id, g.name, info.country, info.flag, techCount, g.software.length, selectedGroups.has(g.id)?'Yes':'No', groupUrl(g.id)]));
    });
    downloadCSV(`${fw}-attack-groups-${ts}.csv`, rows);
  }

  else if (type === 'mitigations') {
    const mitCount = {};
    Object.keys(hm).forEach(tid => {
      const tech = techById[tid];
      if (!tech) return;
      tech.mitigations.forEach(mit => {
        if (!mitCount[mit.id]) mitCount[mit.id] = {name:mit.name, techIds:[], aptCount:0};
        mitCount[mit.id].techIds.push(tid);
        mitCount[mit.id].aptCount += hm[tid].count;
      });
    });
    const sorted = Object.entries(mitCount).sort((a,b)=>b[1].aptCount-a[1].aptCount);
    const rows = [csvRow(['Rank','Mitigation ID','Mitigation Name','Techniques Covered','Technique IDs','Priority Score','MITRE URL'])];
    sorted.forEach(([mid, info], i) => {
      rows.push(csvRow([i+1, mid, info.name, info.techIds.length, info.techIds.join('; '), info.aptCount, mitUrl(mid)]));
    });
    downloadCSV(`${fw}-attack-mitigations-${ts}.csv`, rows);
  }

  else if (type === 'detections') {
    const detCount = {};
    Object.keys(hm).forEach(tid => {
      const tech = techById[tid];
      if (!tech) return;
      tech.detections.forEach(det => {
        if (!detCount[det.id]) detCount[det.id] = {name:det.name, techIds:[], aptCount:0};
        detCount[det.id].techIds.push(tid);
        detCount[det.id].aptCount += hm[tid].count;
      });
    });
    const sorted = Object.entries(detCount).sort((a,b)=>b[1].aptCount-a[1].aptCount);
    const rows = [csvRow(['Rank','Detection ID','Detection Strategy','Techniques Covered','Technique IDs','Priority Score','MITRE URL'])];
    sorted.forEach(([did, info], i) => {
      rows.push(csvRow([i+1, did, info.name, info.techIds.length, info.techIds.join('; '), info.aptCount, detUrl(did)]));
    });
    downloadCSV(`${fw}-attack-detections-${ts}.csv`, rows);
  }

  else if (type === 'full') {
    const allTechIds = d.techniques.map(t => t.id);
    const rows = [csvRow(['Group ID','Group Name','Country','Group MITRE URL',...allTechIds])];
    rows.push(csvRow(['','','','',...allTechIds.map(t => techById[t]?.name || t)]));
    rows.push(csvRow(['','','','',...allTechIds.map(t => techUrl(t))]));
    d.groups.forEach(g => {
      if (!selectedGroups.has(g.id)) return;
      const info = activeGroupCountry(g.id);
      const techs = getGroupTechs(g);
      rows.push(csvRow([g.id, g.name, info.country, groupUrl(g.id), ...allTechIds.map(t => techs.has(t)?'1':'0')]));
    });
    downloadCSV(`${fw}-attack-full-matrix-${ts}.csv`, rows);
  }
}

// ── Tab Switching ──────────────────────────────────────────────────────────
function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.top-tab').forEach(el => {
    el.classList.toggle('active', el.getAttribute('onclick').includes(`'${tab}'`));
  });
  document.querySelectorAll('.tab-content').forEach(el => {
    el.classList.toggle('active', el.id === 'tab-' + tab);
  });
  renderAll();
}

// ── Main Render ────────────────────────────────────────────────────────────
function renderAll() {
  if (dualMode) {
    renderCountryFilter(); // renders both dual APT lists
    updateStats({});       // hides stats bar
    if (currentTab === 'heatmap') {
      renderDualHeatmaps();
    } else {
      // For non-heatmap tabs in dual mode, merge both heat maps
      const hmICS = computeHeatMapFor(DATA.groups, 'ics', selectedGroupsICS);
      const hmEnt = computeHeatMapFor(ENT_DATA.groups, 'enterprise', selectedGroupsEnt);
      // Merge: combine counts keyed by tech id
      const hmMerged = { ...hmICS };
      Object.entries(hmEnt).forEach(([tid, v]) => {
        if (hmMerged[tid]) {
          hmMerged[tid] = { count: hmMerged[tid].count + v.count, groups: [...hmMerged[tid].groups, ...v.groups] };
        } else {
          hmMerged[tid] = v;
        }
      });
      if (currentTab === 'top-ttps')        renderTopTTPs(hmMerged);
      else if (currentTab === 'top-software')    renderTopSoftware(hmMerged);
      else if (currentTab === 'top-detections')  renderTopDetections(hmMerged);
      else if (currentTab === 'top-mitigations') renderTopMitigations(hmMerged);
    }
    return;
  }

  renderCountryFilter();
  renderAptList();
  const hm = computeHeatMap();
  updateStats(hm);
  if (currentTab === 'heatmap')              renderHeatmap(hm);
  else if (currentTab === 'top-ttps')        renderTopTTPs(hm);
  else if (currentTab === 'top-software')    renderTopSoftware(hm);
  else if (currentTab === 'top-detections')  renderTopDetections(hm);
  else if (currentTab === 'top-mitigations') renderTopMitigations(hm);
}

// Close modal on overlay click
document.getElementById('exportModal').addEventListener('click', function(e) {
  if (e.target === this) closeExportModal();
});

// ── Mobile helpers ────────────────────────────────────────────────
function toggleMobileApt() {
  const panel = dualMode
    ? document.getElementById('aptPanelDual')
    : document.getElementById('aptPanelSingle');
  const btn = document.getElementById('mobileAptToggle');
  if (!panel) return;
  const isClosed = panel.classList.toggle('mobile-closed');
  btn.textContent = isClosed ? '☰ Show Threat Actors' : '✕ Hide Threat Actors';
}

renderAll();
</script>
