<!DOCTYPE html>
<html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FLYNN's README CTI Heatmap V2026.3.18</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&display=swap');

  :root {
    --tron-blue: #00e5ff;
    --tron-blue-dim: #0097a7;
    --tron-orange: #ff6d00;
    --tron-orange-dim: #e65100;
    --tron-bg: #020c14;
    --tron-panel: #041929;
    --tron-panel2: #061e30;
    --tron-border: #00e5ff33;
    --tron-border-bright: #00e5ffaa;
    --tron-text: #b2ebf2;
    --tron-dim: #8aabb8;   /* lightened from #37474f */
    --tron-dim2: #aec8d4;  /* even lighter for secondary text */
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--tron-bg);
    color: var(--tron-text);
    font-family: 'Share Tech Mono', monospace;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  body::before {
    content: '';
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
    pointer-events: none;
    z-index: 9999;
  }

  /* ── Header ─────────────────────────────────────────────────────── */
  header {
    background: var(--tron-panel);
    border-bottom: 2px solid var(--tron-blue);
    padding: 9px 18px;
    display: flex;
    align-items: center;
    gap: 18px;
    flex-shrink: 0;
    box-shadow: 0 0 30px #00e5ff22;
  }

  .logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 36px;
    font-weight: 900;
    color: var(--tron-blue);
    text-shadow: 0 0 20px var(--tron-blue), 0 0 40px var(--tron-blue-dim);
    letter-spacing: 3px;
    white-space: nowrap;
  }
  .logo span { color: var(--tron-orange); text-shadow: 0 0 20px var(--tron-orange); }

  .header-meta { font-size: 11px; color: var(--tron-dim2); letter-spacing: 1px; }
  .header-meta strong { color: var(--tron-blue); }

  .header-actions { margin-left: auto; display: flex; gap: 8px; }

  .btn-export {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1.5px;
    padding: 6px 14px;
    background: rgba(255,109,0,0.12);
    border: 1px solid var(--tron-orange);
    color: var(--tron-orange);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .btn-export:hover { background: rgba(255,109,0,0.25); box-shadow: 0 0 12px rgba(255,109,0,0.4); }

  .framework-switcher {
    display: flex;
    border: 1px solid var(--tron-blue-dim);
    overflow: hidden;
  }
  .fw-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 6px 14px;
    background: transparent;
    border: none;
    color: var(--tron-dim2);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .fw-btn:hover { background: rgba(0,229,255,0.08); color: var(--tron-blue); }
  .fw-btn.active {
    background: rgba(0,229,255,0.15);
    color: var(--tron-blue);
    text-shadow: 0 0 8px var(--tron-blue);
  }
  .fw-btn:first-child { border-right: 1px solid var(--tron-blue-dim); }

  .fw-btn-solo {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1px;
    padding: 6px 12px;
    background: rgba(0,229,255,0.06);
    border: 1px solid var(--tron-blue-dim);
    color: var(--tron-dim2);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .fw-btn-solo:hover { background: rgba(0,229,255,0.14); color: var(--tron-blue); border-color: var(--tron-blue); }
  .fw-btn-solo.active {
    background: rgba(255,109,0,0.15);
    border-color: var(--tron-orange);
    color: var(--tron-orange);
    text-shadow: 0 0 8px var(--tron-orange);
  }

  /* Sub-technique cells — slightly narrower, lighter top bar */
  .ttp-cell.sub-tech {
    width: 120px;
    border-left: 2px solid rgba(0,229,255,0.2);
    margin-left: 4px;
    opacity: 0.9;
  }
  .ttp-cell.sub-tech .ttp-id { font-size: 7px; }
  .ttp-cell.sub-tech .ttp-name { font-size: 8px; }

  /* Parent cell when subs are shown — slightly bolder header */
  .ttp-cell.has-subs {
    border-bottom: 2px solid rgba(0,229,255,0.3);
    margin-bottom: 2px;
  }

  /* ── Dual heatmap layout ─────────────────────────────────────── */
  .dual-wrapper {
    flex: 1;
    display: flex;
    overflow: hidden;
    gap: 0;
  }

  .dual-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
  }

  .dual-pane + .dual-pane {
    border-left: 2px solid var(--tron-border-bright);
  }

  .dual-pane-header {
    font-family: 'Orbitron', sans-serif;
    font-size: 9px;
    letter-spacing: 2px;
    padding: 6px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--tron-border);
    flex-shrink: 0;
  }

  .dual-pane-header.ics-header {
    background: rgba(0,229,255,0.06);
    color: var(--tron-blue);
  }

  .dual-pane-header.ent-header {
    background: rgba(255,109,0,0.06);
    color: var(--tron-orange);
    border-left: none;
  }

  .dual-pane-header .pane-title { font-size: 10px; font-weight: 700; letter-spacing: 2px; }
  .dual-pane-header .pane-stats { font-size: 9px; opacity: 0.7; margin-left: auto; }

  /* APT panel in dual mode: split into two sub-panels */
  .apt-panel.dual-apt {
    width: 280px;
  }

  .dual-apt-split {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
  }

  .dual-apt-section {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }

  .dual-apt-section + .dual-apt-section {
    border-top: 2px solid var(--tron-border-bright);
  }

  .dual-apt-section-header {
    font-family: 'Orbitron', sans-serif;
    font-size: 8px;
    letter-spacing: 1.5px;
    padding: 6px 14px 4px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dual-apt-section-header.ics-hdr { color: var(--tron-blue); background: rgba(0,229,255,0.05); border-bottom: 1px solid rgba(0,229,255,0.2); }
  .dual-apt-section-header.ent-hdr { color: var(--tron-orange); background: rgba(255,109,0,0.05); border-bottom: 1px solid rgba(255,109,0,0.2); }

  .dual-apt-section .apt-list { overflow-y: auto; flex: 1; }
  .dual-apt-section .apt-controls { flex-shrink: 0; }

  /* ── Top Tabs ───────────────────────────────────────────────────── */
  .top-tabs {
    background: var(--tron-panel2);
    border-bottom: 1px solid var(--tron-border);
    display: flex;
    flex-shrink: 0;
    padding: 0 18px;
    gap: 2px;
  }

  .top-tab {
    font-family: 'Orbitron', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    padding: 8px 16px;
    border: none;
    background: transparent;
    color: var(--tron-dim);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .top-tab:hover { color: var(--tron-blue); }
  .top-tab.active { color: var(--tron-blue); border-bottom: 2px solid var(--tron-blue); text-shadow: 0 0 10px var(--tron-blue); }

  /* ── Main Layout ────────────────────────────────────────────────── */
  .main { display: flex; flex: 1; overflow: hidden; }

  /* ── Left APT Panel ─────────────────────────────────────────────── */
  .apt-panel {
    width: 270px;
    flex-shrink: 0;
    background: var(--tron-panel);
    border-right: 1px solid var(--tron-border-bright);
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 20px #00e5ff0a;
  }

  .apt-panel-header {
    font-family: 'Orbitron', sans-serif;
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--tron-blue-dim);
    padding: 10px 14px 6px;
    border-bottom: 1px solid var(--tron-border);
    text-transform: uppercase;
  }

  /* Country filter */
  .country-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 7px 10px;
    border-bottom: 1px solid var(--tron-border);
  }

  .country-chip {
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid var(--tron-border);
    background: transparent;
    color: var(--tron-dim2);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    border-radius: 2px;
  }
  .country-chip:hover { border-color: var(--tron-blue-dim); color: var(--tron-blue); }
  .country-chip.active {
    background: rgba(0,229,255,0.12);
    border-color: var(--tron-blue);
    color: var(--tron-blue);
    text-shadow: 0 0 6px var(--tron-blue);
  }

  .apt-controls {
    display: flex;
    gap: 4px;
    padding: 5px 10px;
    border-bottom: 1px solid var(--tron-border);
  }
  .apt-ctrl-btn {
    flex: 1;
    padding: 5px 4px;
    background: rgba(0,229,255,0.05);
    border: 1px solid var(--tron-border);
    color: var(--tron-dim2);
    font-family: 'Orbitron', sans-serif;
    font-size: 7px;
    letter-spacing: 0.5px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .apt-ctrl-btn:hover { background: rgba(0,229,255,0.12); color: var(--tron-blue); border-color: var(--tron-blue); }

  .apt-list { overflow-y: auto; flex: 1; padding: 4px 0; }
  .apt-list::-webkit-scrollbar { width: 3px; }
  .apt-list::-webkit-scrollbar-track { background: var(--tron-panel); }
  .apt-list::-webkit-scrollbar-thumb { background: var(--tron-blue-dim); border-radius: 2px; }

  .apt-item {
    padding: 10px 14px;
    cursor: pointer;
    font-size: 11px;
    color: var(--tron-dim2);
    border-left: 3px solid transparent;
    transition: all 0.15s;
    display: flex;
    flex-direction: column;
    gap: 3px;
    border-bottom: 1px solid rgba(0,229,255,0.05);
  }
  .apt-item.hidden { display: none; }
  .apt-item:hover { background: rgba(0,229,255,0.05); color: var(--tron-blue); border-left-color: var(--tron-blue-dim); }
  .apt-item.active { background: rgba(0,229,255,0.1); color: var(--tron-blue); border-left-color: var(--tron-blue); text-shadow: 0 0 8px rgba(0,229,255,0.4); }

  .apt-row1 { display: flex; align-items: center; gap: 6px; }
  .apt-name { font-size: 16px; letter-spacing: 0.5px; flex: 1; font-weight: 600; }
  .apt-flag { font-size: 15px; }
  .apt-id { font-size: 9px; color: var(--tron-blue-dim); }
  .apt-meta { display: flex; align-items: center; gap: 8px; }
  .apt-country { font-size: 9px; color: var(--tron-dim2); }
  .apt-count { font-size: 9px; color: var(--tron-orange); font-family: 'Orbitron', sans-serif; }
  .apt-item.active .apt-count { text-shadow: 0 0 6px var(--tron-orange); }

  .apt-desc {
    font-size: 9px;
    color: var(--tron-dim2);
    line-height: 1.45;
    opacity: 0.75;
    margin-top: 1px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: opacity 0.15s;
  }
  .apt-item:hover .apt-desc,
  .apt-item.active .apt-desc {
    opacity: 1;
    color: var(--tron-text);
    -webkit-line-clamp: 3;
  }

  .apt-link {
    font-size: 8px;
    color: var(--tron-blue-dim);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s;
    margin-top: 1px;
  }
  .apt-item:hover .apt-link, .apt-item.active .apt-link { opacity: 1; }
  .apt-link:hover { color: var(--tron-blue); text-decoration: underline; }

  /* ── Content Area ───────────────────────────────────────────────── */
  .content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  .stats-bar {
    background: var(--tron-panel2);
    border-bottom: 1px solid var(--tron-border);
    padding: 7px 18px;
    display: flex;
    gap: 28px;
    align-items: center;
    flex-shrink: 0;
  }
  .stat { display: flex; flex-direction: column; gap: 1px; }
  .stat-label { font-size: 12px; color: var(--tron-white); letter-spacing: 1px; text-transform: uppercase; }
  .stat-value { font-family: 'Orbitron', sans-serif; font-size: 14px; color: var(--tron-blue); font-weight: 700; }
  .stat-value.orange { color: var(--tron-orange); }
  .selected-apts { flex: 1; font-size: 10px; color: var(--tron-dim2); text-align: right; }

  .tab-content { flex: 1; overflow: hidden; display: none; }
  .tab-content.active { display: flex; flex-direction: column; }

  /* ── HEATMAP — Horizontal layout ────────────────────────────────── */
  .heatmap-scroll {
    flex: 1;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    padding: 12px;
  }
  .heatmap-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
  .heatmap-scroll::-webkit-scrollbar-track { background: var(--tron-panel); }
  .heatmap-scroll::-webkit-scrollbar-thumb { background: var(--tron-blue-dim); border-radius: 3px; }

  /* Horizontal: columns = tactics, rows = technique cards */
  .heatmap-grid {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    min-width: max-content;
  }

  .tactic-col {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 138px;
    flex-shrink: 0;
  }

  .tactic-header {
    font-family: 'Orbitron', sans-serif;
    font-size: 12px;
    letter-spacing: 1.5px;
    color: var(--tron-blue);
    text-transform: uppercase;
    padding: 6px 8px;
    border: 1px solid var(--tron-border-bright);
    background: rgba(0,229,255,0.04);
    border-bottom: 2px solid var(--tron-blue-dim);
    line-height: 1.3;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tactic-header .tactic-id-small { font-size: 7px; opacity: 0.6; }
  .tactic-header .tactic-count { font-size: 8px; color: var(--tron-orange); font-family: 'Orbitron', sans-serif; margin-top: 1px; }

  .ttp-cell {
    padding: 6px 8px;
    border: 1px solid var(--tron-border);
    background: #050f1a;
    cursor: pointer;
    transition: all 0.18s;
    position: relative;
    overflow: hidden;
  }

  .ttp-cell::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--heat-color, transparent);
    box-shadow: 0 0 5px var(--heat-color, transparent);
  }

  .ttp-cell:hover {
    border-color: var(--tron-blue);
    z-index: 10;
    transform: scale(1.04);
    box-shadow: 0 0 14px rgba(0,229,255,0.25);
  }

  .ttp-id { font-size: 8px; color: var(--tron-blue-dim); margin-bottom: 2px; }
  .ttp-name { font-size: 9px; line-height: 1.3; color: var(--tron-text); }
  .ttp-heat {
    font-family: 'Orbitron', sans-serif;
    font-size: 10px;
    font-weight: 700;
    margin-top: 3px;
    color: var(--heat-color, var(--tron-dim));
  }
  .ttp-link {
    font-size: 7px;
    color: var(--tron-blue-dim);
    text-decoration: none;
    display: none;
    margin-top: 2px;
  }
  .ttp-cell:hover .ttp-link { display: block; }
  .ttp-link:hover { color: var(--tron-blue); text-decoration: underline; }

  /* Heat classes */
  .heat-0 { --heat-color: transparent; }
  .heat-1 { --heat-color: #00bcd4; background: rgba(0,188,212,0.07) !important; }
  .heat-2 { --heat-color: #00e5ff; background: rgba(0,229,255,0.11) !important; }
  .heat-3 { --heat-color: #29b6f6; background: rgba(41,182,246,0.16) !important; }
  .heat-4 { --heat-color: #ff9800; background: rgba(255,152,0,0.16) !important; }
  .heat-5 { --heat-color: #ff6d00; background: rgba(255,109,0,0.20) !important; }
  .heat-6 { --heat-color: #ff3d00; background: rgba(255,61,0,0.26) !important; }

  @keyframes pulse-hot {
    0%,100% { box-shadow: 0 0 4px rgba(255,61,0,0.3), inset 0 0 8px rgba(255,61,0,0.08); }
    50%      { box-shadow: 0 0 12px rgba(255,61,0,0.55), inset 0 0 14px rgba(255,61,0,0.14); }
  }
  .heat-6 { animation: pulse-hot 3s ease-in-out infinite; }

  /* Legend */
  .legend {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--tron-panel2);
    border-top: 1px solid var(--tron-border);
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .legend-label { font-size: 11px; color: var(--tron-dim); letter-spacing: 1px; text-transform: uppercase; margin-right: 4px; }
  .legend-item { display: flex; align-items: center; gap: 4px; }
  .legend-dot { width: 13px; height: 13px; border-radius: 2px; }
  .legend-text { font-size: 11px; color: var(--tron-dim2); }

  /* ── Tooltip ────────────────────────────────────────────────────── */
  .tooltip {
    position: fixed;
    background: var(--tron-panel);
    border: 1px solid var(--tron-blue);
    box-shadow: 0 0 25px rgba(0,229,255,0.25);
    padding: 11px 14px;
    z-index: 10000;
    pointer-events: auto;
    max-width: 320px;
    display: none;
    font-size: 11px;
    line-height: 1.5;
  }
  .tooltip.visible { display: block; }
  .tooltip-title { font-family: 'Orbitron', sans-serif; font-size: 11px; color: var(--tron-blue); margin-bottom: 4px; text-shadow: 0 0 8px var(--tron-blue); }
  .tooltip-id { font-size: 9px; color: var(--tron-blue-dim); margin-bottom: 5px; }
  .tooltip-apts { font-size: 10px; color: #ff9800; margin-bottom: 4px; }
  .tooltip-section { margin-top: 5px; }
  .tooltip-section-label { font-size: 8px; color: var(--tron-orange); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2px; }
  .tooltip-item { font-size: 9px; color: var(--tron-text); padding-left: 8px; }
  .tooltip-item::before { content: '▸ '; color: var(--tron-blue-dim); }
  .tooltip-link { font-size: 9px; color: var(--tron-blue-dim); margin-top: 5px; display: block; }

  /* ── List Panels ────────────────────────────────────────────────── */
  .list-panel { flex: 1; overflow: auto; padding: 12px 18px; }
  .list-panel::-webkit-scrollbar { width: 5px; }
  .list-panel::-webkit-scrollbar-track { background: var(--tron-panel); }
  .list-panel::-webkit-scrollbar-thumb { background: var(--tron-blue-dim); border-radius: 3px; }

  .top-list { width: 100%; border-collapse: collapse; }
  .top-list th {
    font-family: 'Orbitron', sans-serif;
    font-size: 8px;
    letter-spacing: 1.5px;
    color: var(--tron-blue-dim);
    text-transform: uppercase;
    text-align: left;
    padding: 6px 12px;
    border-bottom: 1px solid var(--tron-border-bright);
    position: sticky;
    top: 0;
    background: var(--tron-bg);
    z-index: 2;
  }
  .top-list td { padding: 7px 12px; border-bottom: 1px solid var(--tron-border); font-size: 11px; vertical-align: top; }
  .top-list tr:hover td { background: rgba(0,229,255,0.03); }

  .rank-num { font-family: 'Orbitron', sans-serif; font-size: 12px; font-weight: 700; color: var(--tron-dim2); width: 32px; text-align: center; }
  .rank-1 .rank-num { color: #ff3d00; text-shadow: 0 0 10px #ff3d00; }
  .rank-2 .rank-num { color: #ff9800; text-shadow: 0 0 8px #ff9800; }
  .rank-3 .rank-num { color: #ffc107; text-shadow: 0 0 6px #ffc107; }

  .item-id { font-size: 8px; color: var(--tron-blue-dim); margin-bottom: 1px; }
  .item-name { color: var(--tron-text); font-size: 11px; }
  .item-sub { font-size: 9px; color: var(--tron-dim2); margin-top: 1px; }
  .mitre-link { font-size: 8px; color: var(--tron-blue-dim); text-decoration: none; margin-top: 2px; display: inline-block; }
  .mitre-link:hover { color: var(--tron-blue); text-decoration: underline; }

  .bar-cell { width: 200px; }
  .bar-outer { height: 13px; background: rgba(0,229,255,0.05); border: 1px solid var(--tron-border); position: relative; overflow: hidden; }
  .bar-inner { height: 100%; background: linear-gradient(90deg, var(--tron-blue-dim), var(--tron-blue)); box-shadow: 0 0 8px var(--tron-blue); transition: width 0.5s ease; }
  .bar-count { position: absolute; right: 4px; top: 50%; transform: translateY(-50%); font-size: 8px; color: var(--tron-blue); font-family: 'Orbitron', sans-serif; }
