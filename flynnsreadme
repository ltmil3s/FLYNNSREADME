  COUNTRIES_ENT = [...entCountries].sort();
}

function computeHeatMapFor(groups, fw, selSet) {
  const hm = {};
  groups.forEach(g => {
    if (!selSet.has(g.id)) return;
    getGroupTechs(g, fw).forEach(tid => {
      if (!hm[tid]) hm[tid] = { count: 0, groups: [] };
      hm[tid].count++;
      hm[tid].groups.push(g.name);
    });
  });
  return hm;
}

